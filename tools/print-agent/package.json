{
  "name": "ironwaves-print-agent",
  "private": true,
  "version": "0.2.0",
  "type": "commonjs",
  "main": "ironwaves-print-agent.js",
  "scripts": {
    "start": "node ironwaves-print-agent.js",
    "build:exe": "pkg ironwaves-print-agent.js --targets node18-win-x64 --output dist/ironwaves-print-agent.exe --public",
    "build:mac:exe:arm64": "pkg ironwaves-print-agent.js --targets node18-macos-arm64 --output dist/ironwaves-print-agent-macos-arm64 --public",
    "build:mac:exe:x64": "pkg ironwaves-print-agent.js --targets node18-macos-x64 --output dist/ironwaves-print-agent-macos-x64 --public",
    "build:mac:pkg": "bash ./build/macos/build-macos-pkg.sh",
    "build:installer": "powershell -ExecutionPolicy Bypass -File ./build/build-installer.ps1",
    "build:all": "npm run build:exe && npm run build:installer",
    "build:mac:all": "npm run build:mac:exe:arm64 && npm run build:mac:pkg"
  },
  "devDependencies": {
    "pkg": "^5.8.1"
  }
}
