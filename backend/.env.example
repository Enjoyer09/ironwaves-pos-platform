APP_ENV=production
APP_URL=https://api.ironwaves.store

DATABASE_URL=postgresql+psycopg2://user:pass@host:5432/dbname
REDIS_URL=redis://localhost:6379/0

JWT_SECRET=change-me
SUPERADMIN_PASSWORD=change-me
SUPERADMIN_USERNAME=ironwaves_owner
PASSWORD_MIN_LENGTH=10
PASSWORD_REQUIRED_CHARACTER_CLASSES=4

METRICS_BEARER_TOKEN=change-me
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.0

CORS_ORIGINS=https://www.ironwaves.store,https://ironwaves.store,https://super.ironwaves.store,https://*.ironwaves.store,http://localhost:5173
REQUEST_LOGGING_ENABLED=true
TENANT_RESOLUTION_DEBUG=true
INCLUDE_TENANT_DEBUG_HEADER=false
ENABLE_PUBLIC_TENANT_DEBUG=false

STARTUP_CREATE_ALL_ENABLED=false
STARTUP_RUNTIME_MIGRATIONS_ENABLED=false
STARTUP_SCHEMA_GUARD_ENABLED=true
STARTUP_DATA_RETENTION_CLEANUP_ENABLED=true

# Demo tenant safety (production override disabled by default)
DEMO_TENANT_ENABLED=false
SEED_DEMO_USERS=false
ALLOW_DEMO_IN_PRODUCTION=false
DEMO_ADMIN_PASSWORD=
DEMO_MANAGER_PASSWORD=
DEMO_STAFF_PIN=
DEMO_KITCHEN_PIN=

# Stock photo API for AI menu image assignment (free: https://www.pexels.com/api/)
PEXELS_API_KEY=
# Unsplash API for higher quality food photos (free: https://unsplash.com/developers)
UNSPLASH_ACCESS_KEY=
