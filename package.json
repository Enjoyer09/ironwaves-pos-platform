{
  "name": "react-vite-tailwind",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build && cp public/sw.js dist/sw.js",
    "preview": "vite preview",
    "start": "node server.js",
    "print-agent": "node tools/print-agent/ironwaves-print-agent.js",
    "print-agent:build:exe": "npm --prefix tools/print-agent run build:exe",
    "print-agent:build:installer": "npm --prefix tools/print-agent run build:installer",
    "print-agent:build:all": "npm --prefix tools/print-agent run build:all"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.1",
    "@capacitor/camera": "^8.2.0",
    "@capacitor/cli": "^8.4.1",
    "@capacitor/core": "^8.4.1",
    "@capacitor/haptics": "^8.0.2",
    "@capacitor/ios": "^8.4.1",
    "@capacitor/push-notifications": "^8.1.1",
    "@fontsource/geist-sans": "^5.2.5",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "decimal.js": "^10.6.0",
    "i18next": "^25.8.20",
    "jsbarcode": "^3.12.3",
    "jszip": "^3.10.1",
    "lucide-react": "^0.577.0",
    "qrcode": "^1.5.4",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-i18next": "^16.5.8",
    "react-router-dom": "^7.13.1",
    "recharts": "^3.8.0",
    "tailwind-merge": "^3.4.0",
    "uuid": "^13.0.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@tailwindcss/vite": "4.1.17",
    "@types/node": "^22.0.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.1.1",
    "tailwindcss": "4.1.17",
    "typescript": "5.9.3",
    "vite": "^7.3.6",
    "vite-plugin-pwa": "^1.3.0",
    "vite-plugin-singlefile": "2.3.0"
  }
}
